# ─── Phase 0 (required) ───────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Corsair SDK — key-encryption key (NOT "CORSAIR_SECRET")
# Generate once and keep stable: openssl rand -base64 32
# If you change this after corsair:setup, run: bun run corsair:reset
CORSAIR_KEK=

# Google OAuth app (Gmail + Calendar scopes) — shared by Better Auth + Corsair plugins
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URLs
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ─── Phase 1 (auth) ─────────────────────────────────────────────
# Session signing — required when enabling Better Auth sign-in
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Optional — @better-auth/infra (Dash/Sentinel hosted features only)
BETTER_AUTH_API_KEY=

# ─── Phase 2+ ─────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=

PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

CRON_SECRET=
