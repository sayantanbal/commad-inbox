# ─── Phase 0 (required) ───────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Corsair SDK — key-encryption key (NOT "CORSAIR_SECRET")
# Generate once and keep stable: openssl rand -base64 32
# If you change this after corsair:setup, run: bun run corsair:reset
CORSAIR_KEK=

# Google OAuth app (Gmail + Calendar scopes) — shared by Better Auth + Corsair plugins
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URLs
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ─── Phase 1 (auth) ─────────────────────────────────────────────
# Session signing — required when enabling Better Auth sign-in
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Optional — @better-auth/infra (Dash/Sentinel hosted features only)
BETTER_AUTH_API_KEY=

# ─── Phase 2 (webhooks + AI triage) ───────────────────────────────
# At least one provider key is required for AI features.
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# Default AI provider when no saved preference (openai | gemini)
NEXT_PUBLIC_DEFAULT_AI_PROVIDER=openai

# Gmail push — full topic name: projects/<project>/topics/<name>
GMAIL_PUBSUB_TOPIC=

PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

CRON_SECRET=

# Vercel Cron (daily 4:00 UTC): GET /api/cron/renew-watches — renews Gmail + Calendar push watches
# Set CRON_SECRET and ping POST /api/cron/process-due every minute
# (cron-job.org or Upstash QStash) to dispatch send-later + expire snoozes.
