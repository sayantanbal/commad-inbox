    "postgres": "^3.4.9",
    "pusher": "^5.3.4",
    "pusher-js": "^8.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hotkeys-hook": "^5.1.0",
    "react-resizable-panels": "^4.11.2",
    "server-only": "^0.0.1",
