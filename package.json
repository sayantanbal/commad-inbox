{
  "name": "command-inbox",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "docs:dev": "bun run --filter command-inbox-docs dev",
    "docs:build": "bun run --filter command-inbox-docs build",
    "dev": "next dev",
    "build": "next build",
    "test": "bun test src/lib/__tests__",
    "start": "next start",
    "lint": "next lint",
    "db:migrate": "bun scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "corsair:setup": "bun scripts/corsair-setup.ts",
    "corsair:reset": "bun scripts/corsair-reset.ts",
    "smoke:corsair": "bun scripts/smoke-corsair.ts",
    "gmail:watch": "bun scripts/gmail-watch.ts",
    "calendar:watch": "bun scripts/calendar-watch.ts",
    "watches:renew": "bun scripts/renew-watches.ts",
    "phase0": "bun run db:migrate && bun run corsair:setup && bun run smoke:corsair"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/mcp": "^1.0.50",
